# Host and container listen port
V2RAY_PORT=10086

# Generate with: docker run --rm v2fly/v2fly-core:latest v2ray uuid
V2RAY_UUID=640b6169-cd66-4d42-bb8f-25b62930e925

# VMess settings
V2RAY_ALTER_ID=0
V2RAY_WS_PATH=/ray

# V2Ray log level: debug | info | warning | error | none
V2RAY_LOG_LEVEL=warning

# Clash subscription conversion (subconverter)
V2RAY_SUBCONVERTER_TEMPLATE=https://raw.githubusercontent.com/ACL4SSR/ACL4SSR/master/Clash/config/ACL4SSR_Online.ini
